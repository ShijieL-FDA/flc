{
  "openapi": "3.1.0",
  "info": {
    "title": "Fat Loss Coach Health Check",
    "version": "1.0.0",
    "description": "Minimal authenticated schema used to prove Custom GPT Actions send X-API-Key correctly."
  },
  "servers": [
    {
      "url": "https://flc-d7oi.onrender.com",
      "description": "Render production API"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "summary": "Check whether the authenticated API is reachable.",
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        }
      }
    }
  }
}
