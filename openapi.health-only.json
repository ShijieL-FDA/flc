{
  "openapi": "3.1.0",
  "info": {
    "title": "FLC Health Only API",
    "version": "1.0.0",
    "description": "Health-only debug schema for the fat loss coach backend."
  },
  "servers": [
    {
      "url": "https://flc-d7oi.onrender.com",
      "description": "Render production API"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "summary": "Check authenticated backend health.",
        "responses": {
          "200": {
            "description": "Backend is healthy.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "spreadsheet_id_configured": {
                      "type": "boolean"
                    },
                    "timezone": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key."
          }
        }
      }
    }
  }
}
